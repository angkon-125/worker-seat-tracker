# APP CONFIG
APP_NAME="Worker Seat Tracker"
DEBUG=True

# DATABASE
# Change this for production use
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worker_seat_tracker

# VISION PIPELINE
# Path to YOLO model (auto-downloaded by Ultralytics if not exists)
YOLO_MODEL_PATH=yolov8n.pt
# Processes every N frames (higher = lower CPU usage)
FRAME_SKIP=5
# % of overlap required to mark seat as occupied (0.0 to 1.0)
OCCUPANCY_THRESHOLD=0.3
# Seconds to wait before marking a seat as empty after last detection
SEAT_EXIT_DELAY_SECONDS=5

# REDIS (Optional for live state)
REDIS_URL=redis://localhost:6379/0
